{
  "App": {
    "GitHub": {
      "TokenEnvVar": "GITHUB_TOKEN"
    },
    "OpenCode": {
      "CliPath": ""
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Level:Abbreviation}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
